---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const lastUpdated = "June 13, 2026";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Privacy Policy — Digital Signature Pro",
  "url": "https://www.digitalsignaturepro.com/privacy-policy/",
  "description": "Privacy Policy for Digital Signature Pro. We collect no personal data, store no signatures, and use no tracking cookies.",
  "publisher": {
    "@type": "Organization",
    "name": "Digital Signature Pro",
    "url": "https://www.digitalsignaturepro.com"
  }
};
---

<Layout
  title="Privacy Policy — Digital Signature Pro"
  description="Digital Signature Pro respects your privacy. We collect no personal data, store no signatures, and use no tracking cookies. Everything runs in your browser."
  canonical="https://www.digitalsignaturepro.com/privacy-policy/"
  schema={schema}
>
  <Header />

  <main id="main-content">
    <section class="pt-16 pb-12 sm:pt-24 sm:pb-16">
      <div class="mx-auto max-w-3xl px-4 sm:px-6">

        <h1 class="text-4xl font-black tracking-tight sm:text-5xl mb-3" style="color:var(--color-text);">
          Privacy Policy
        </h1>
        <p class="text-sm mb-10" style="color:var(--color-text-muted);">Last updated: {lastUpdated}</p>

        <div class="rounded-2xl p-5 mb-10" style="background:rgba(34,197,94,0.06);border:1px solid rgba(34,197,94,0.2);">
          <p class="text-sm font-semibold" style="color:#166534;">
            ✓ Short version: We collect no personal data, store no signatures, and track nothing. Your name stays in your browser.
          </p>
        </div>

        <div class="prose-content space-y-10" style="color:var(--color-text-muted);">

          <div>
            <h2 class="text-xl font-black mb-3" style="color:var(--color-text);">1. Who We Are</h2>
            <p class="text-base leading-relaxed">
              Digital Signature Pro ("we", "us", "our") operates the website at <a href="https://www.digitalsignaturepro.com" style="color:var(--color-accent);">www.digitalsignaturepro.com</a> — a free online signature generator tool. You can contact us at <a href="mailto:contact@digitalsignaturepro.com" style="color:var(--color-accent);">contact@digitalsignaturepro.com</a>.
            </p>
          </div>

          <div>
            <h2 class="text-xl font-black mb-3" style="color:var(--color-text);">2. Data We Collect</h2>
            <p class="text-base leading-relaxed mb-3">
              We do not collect, store, or transmit any personal information. Specifically:
            </p>
            <ul class="space-y-2 text-sm list-none">
              <li class="flex items-start gap-2"><span style="color:var(--color-accent);">→</span> <span><strong style="color:var(--color-text);">Your name or signature:</strong> Processed entirely in your browser. Never sent to our servers.</span></li>
              <li class="flex items-start gap-2"><span style="color:var(--color-accent);">→</span> <span><strong style="color:var(--color-text);">Account data:</strong> We have no accounts. No email, password, or profile is ever created.</span></li>
              <li class="flex items-start gap-2"><span style="color:var(--color-accent);">→</span> <span><strong style="color:var(--color-text);">Payment data:</strong> Our tool is free. We accept no payments and store no financial data.</span></li>
            </ul>
          </div>

          <div>
            <h2 class="text-xl font-black mb-3" style="color:var(--color-text);">3. Cookies & Tracking</h2>
            <p class="text-base leading-relaxed mb-3">
              We use minimal local storage only to remember your theme preference (light or dark mode). No advertising cookies, no cross-site tracking, no fingerprinting.
            </p>
            <p class="text-base leading-relaxed">
              We run <strong style="color:var(--color-text);">no analytics or tracking scripts</strong> of any kind — no Google Analytics, no Vercel Analytics, no advertising or behavioural pixels. We do not measure, profile, or follow your activity across pages.
            </p>
          </div>

          <div>
            <h2 class="text-xl font-black mb-3" style="color:var(--color-text);">4. Third-Party Services</h2>
            <p class="text-base leading-relaxed">
              Our site is hosted on <strong style="color:var(--color-text);">Vercel</strong>. Vercel may log standard server access data (IP address, timestamps, request path) as part of their infrastructure. Please see <a href="https://vercel.com/legal/privacy-policy" target="_blank" rel="noopener noreferrer" style="color:var(--color-accent);">Vercel's Privacy Policy</a> for details. We do not have access to these server-level logs in an identifiable form.
            </p>
          </div>

          <div>
            <h2 class="text-xl font-black mb-3" style="color:var(--color-text);">5. Children's Privacy</h2>
            <p class="text-base leading-relaxed">
              Our service does not knowingly collect data from children under 13. Since we collect no personal data from anyone, this policy applies equally to all users regardless of age.
            </p>
          </div>

          <div>
            <h2 class="text-xl font-black mb-3" style="color:var(--color-text);">6. Changes to This Policy</h2>
            <p class="text-base leading-relaxed">
              If we make material changes to this policy, we will update the "Last updated" date at the top of this page. Continued use of the site after changes constitutes acceptance of the updated policy.
            </p>
          </div>

          <div>
            <h2 class="text-xl font-black mb-3" style="color:var(--color-text);">7. Contact</h2>
            <p class="text-base leading-relaxed">
              Questions about this privacy policy? Email us at <a href="mailto:contact@digitalsignaturepro.com" style="color:var(--color-accent);">contact@digitalsignaturepro.com</a>.
            </p>
          </div>

        </div>

        <div class="mt-12 pt-8" style="border-top:1px solid var(--color-border);">
          <a href="/"
            class="inline-flex items-center gap-2 text-sm font-semibold transition-colors"
            style="color:var(--color-accent);">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
            </svg>
            Back to Signature Generator
          </a>
        </div>

      </div>
    </section>
  </main>

  <Footer />
</Layout>
