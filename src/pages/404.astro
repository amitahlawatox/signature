---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Page Not Found — Digital Signature Pro"
  description="This page doesn't exist. Create your free professional signature with Digital Signature Pro — 10 styles, instant download, no sign-up."
  canonical="https://www.digitalsignaturepro.com/404"
  noIndex={true}
>
  <Header />

  <main id="main-content" class="mx-auto max-w-3xl px-4 sm:px-6 py-20 text-center">

    <!-- Visual indicator -->
    <div class="mb-8 inline-flex h-20 w-20 items-center justify-center rounded-2xl"
      style="background:var(--color-accent-subtle);border:1px solid var(--color-accent-border);">
      <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.8" stroke-linecap="round">
        <path d="M17 3 C17 3 9 3 9 8 C9 13 17 11 17 16 C17 21 9 21 9 21"/>
        <line x1="4" y1="4" x2="20" y2="20" stroke-width="2.2" opacity="0.4"/>
      </svg>
    </div>

    <h1 class="text-3xl font-black tracking-tight sm:text-5xl mb-4" style="color:var(--color-text);">
      Page Not Found
    </h1>

    <p class="mx-auto max-w-md text-base sm:text-lg mb-3" style="color:var(--color-text-muted);">
      The page you're looking for doesn't exist or has moved. Our signature tool is ready for you below.
    </p>

    <p class="text-sm mb-10" style="color:var(--color-text-muted);">
      If you followed a link here, the content may have been updated. Try our generator instead:
    </p>

    <!-- Primary CTA -->
    <a href="/"
      class="inline-flex items-center gap-2.5 rounded-xl px-7 py-3.5 text-base font-bold text-white transition-all hover:opacity-90 active:scale-95 shadow-lg"
      style="background:linear-gradient(135deg, var(--color-accent), var(--color-accent-light));">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M17 3 C17 3 9 3 9 8 C9 13 17 11 17 16 C17 21 9 21 9 21"/>
      </svg>
      Create Your Free Signature
    </a>

    <!-- Secondary links -->
    <div class="mt-8 flex flex-wrap justify-center gap-4 text-sm">
      <a href="/signature/" class="rounded-lg px-4 py-2 font-semibold transition-colors"
        style="color:var(--color-accent);background:var(--color-accent-subtle);border:1px solid var(--color-accent-border);">
        Browse by Name
      </a>
      <a href="/style/" class="rounded-lg px-4 py-2 font-semibold transition-colors"
        style="color:var(--color-accent);background:var(--color-accent-subtle);border:1px solid var(--color-accent-border);">
        Explore Styles
      </a>
    </div>

    <!-- Quick-access popular names -->
    <div class="mt-14 text-left">
      <h2 class="text-sm font-bold uppercase tracking-widest mb-4 text-center" style="color:var(--color-text-muted);">
        Popular Signatures
      </h2>
      <div class="flex flex-wrap justify-center gap-2">
        {['James','Emma','David','Olivia','Noah','Lisa','Priya','Robert','Anjali','Liam'].map(n => (
          <a href={`/signature/${n.toLowerCase()}/`}
            class="rounded-full px-3.5 py-1.5 text-sm font-medium transition-all hover:scale-105"
            style="background:var(--color-surface);border:1px solid var(--color-border);color:var(--color-text-muted);">
            {n}
          </a>
        ))}
      </div>
    </div>

  </main>

  <Footer />
</Layout>
