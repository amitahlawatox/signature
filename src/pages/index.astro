---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SignatureGenerator from '../components/SignatureGenerator';
import { POPULAR_NAMES } from '../lib/names';

const POPULAR = POPULAR_NAMES.slice(0, 24);

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Digital Signature Pro — Free Online Signature Generator",
  "url": "https://www.digitalsignaturepro.com",
  "description": "Create a beautiful free signature online. 10 elegant handwriting styles. Download as PNG or SVG instantly.",
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
};
---

<Layout
  title="Free Signature Generator — Create Professional Signatures Online | Digital Signature Pro"
  description="Create a professional free digital signature in seconds. 10 elegant cursive & calligraphy styles. Type your name, customize color & size, download PNG or SVG. No sign-up needed."
  canonical="https://www.digitalsignaturepro.com/"
  schema={schema}
>
  <Header />

  <main id="main-content">

    <!-- ── HERO ── -->
    <section class="pt-16 pb-12 sm:pt-24 sm:pb-16" style="border-bottom:1px solid var(--color-border);">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 text-center">

        <!-- Badge -->
        <div class="mb-5 inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-sm font-semibold"
          style="background:var(--color-accent-subtle);border:1px solid var(--color-accent-border);color:var(--color-accent);"
          data-scroll="fade">
          ✦ Free &nbsp;·&nbsp; No Sign-Up &nbsp;·&nbsp; Instant Download
        </div>

        <!-- Heading -->
        <h1 class="text-4xl font-black tracking-tight sm:text-6xl leading-none mb-5" data-scroll="fade">
          <span class="gradient-text">Signature</span>
          <span style="color:var(--color-text);"> Generator</span>
        </h1>
        <p class="mx-auto max-w-lg text-base sm:text-lg mb-10" style="color:var(--color-text-muted);" data-scroll="fade">
          Type your name. Pick from <strong style="color:var(--color-text);">10 professional styles</strong> with realistic pen effects. Download PNG or SVG — free, forever.
        </p>

        <!-- ── MAIN TOOL ── -->
        <div data-scroll="fade">
          <SignatureGenerator client:load />
        </div>
      </div>
    </section>

    <!-- ── AD SLOT ── -->
    <div class="mx-auto max-w-4xl px-4 sm:px-6 my-12">
      <div class="ad-slot h-[90px]">· advertisement ·</div>
    </div>

    <!-- ── FEATURES ── -->
    <section class="mx-auto max-w-5xl px-4 sm:px-6 py-12" data-scroll>
      <h2 class="text-2xl font-black text-center mb-2" style="color:var(--color-text);">Why SignatureMakr?</h2>
      <p class="text-center mb-10 text-sm" style="color:var(--color-text-muted);">Built different from the competition</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          { icon: '⚡', title: 'Instant Preview',    desc: 'See your signature update live as you type. Zero lag, zero loading.' },
          { icon: '✍️', title: '10 Unique Styles',   desc: 'From formal calligraphy to expressive brush lettering — all self-hosted fonts.' },
          { icon: '📥', title: 'PNG + SVG Download', desc: '3× retina PNG for email & docs. Scalable SVG for Illustrator & Figma.' },
          { icon: '🔒', title: 'Zero Tracking',      desc: 'No account, no email, no cookies. Everything stays in your browser.' },
          { icon: '🖊️', title: 'Realistic Ink',      desc: 'Ballpoint, fountain pen, and gel pen effects with CSS ink simulation.' },
          { icon: '📱', title: 'Works Everywhere',   desc: 'Pixel-perfect on mobile, tablet, and desktop. No app download needed.' },
        ].map(f => (
          <div class="style-card rounded-2xl p-6" style="background:var(--color-surface);border:1px solid var(--color-border);">
            <div class="mb-3 text-2xl">{f.icon}</div>
            <h3 class="font-bold mb-1.5" style="color:var(--color-text);">{f.title}</h3>
            <p class="text-sm leading-relaxed" style="color:var(--color-text-muted);">{f.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ── BY NAME ── -->
    <section class="mx-auto max-w-5xl px-4 sm:px-6 py-12" data-scroll>
      <div class="rounded-2xl p-8 sm:p-10" style="background:var(--color-surface);border:1px solid var(--color-border);">
        <h2 class="text-xl font-black mb-1.5" style="color:var(--color-text);">Find Your Name</h2>
        <p class="text-sm mb-7" style="color:var(--color-text-muted);">
          Pre-made signature pages for 200+ popular names worldwide
        </p>
        <div class="flex flex-wrap gap-2 mb-6">
          {POPULAR.map(name => (
            <a href={`/signature/${name.toLowerCase()}/`}
              class="rounded-full px-4 py-1.5 text-sm font-semibold transition-all hover:scale-105"
              style="background:var(--color-surface-2);border:1px solid var(--color-border);color:var(--color-text-muted);"
              onmouseover="this.style.borderColor='var(--color-accent-border)';this.style.color='var(--color-accent)'"
              onmouseout="this.style.borderColor='var(--color-border)';this.style.color='var(--color-text-muted)'">
              {name}
            </a>
          ))}
        </div>
        <a href="/signature/"
          class="inline-flex items-center gap-2 rounded-xl px-5 py-2.5 text-sm font-bold text-white transition-all hover:opacity-90"
          style="background:var(--color-accent);">
          View All 200+ Names
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>
    </section>

    <!-- ── HOW IT WORKS ── -->
    <section class="py-14" style="background:var(--color-surface-2);border-top:1px solid var(--color-border);border-bottom:1px solid var(--color-border);" data-scroll>
      <div class="mx-auto max-w-4xl px-4 sm:px-6">
        <h2 class="text-2xl font-black text-center mb-10" style="color:var(--color-text);">How It Works</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
          {[
            { step: '1', title: 'Type Your Name',  desc: 'Enter your name in the input box — any language, any length.' },
            { step: '2', title: 'Pick a Style',    desc: 'Choose from 10 professional cursive and calligraphy styles.' },
            { step: '3', title: 'Download Free',   desc: 'Click download and get a high-res PNG or vector SVG instantly.' },
          ].map(s => (
            <div class="flex flex-col items-center text-center gap-3">
              <div class="flex h-12 w-12 items-center justify-center rounded-full text-base font-black text-white"
                style="background:var(--color-accent);">
                {s.step}
              </div>
              <h3 class="font-bold" style="color:var(--color-text);">{s.title}</h3>
              <p class="text-sm" style="color:var(--color-text-muted);">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── FAQ ── -->
    <section class="mx-auto max-w-3xl px-4 sm:px-6 py-14" data-scroll>
      <h2 class="text-2xl font-black text-center mb-8" style="color:var(--color-text);">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {[
          { q: 'Is SignatureMakr really free?',
            a: 'Yes — completely free, forever. No subscription, no watermark, no hidden fees.' },
          { q: 'Can I use my signature on legal documents?',
            a: 'SignatureMakr creates stylistic signatures for emails, social media, and creative work. For legally binding e-signatures, use a dedicated e-sign service.' },
          { q: 'What formats can I download?',
            a: 'PNG (3× retina-quality, great for emails and documents) and SVG (infinitely scalable vector, perfect for designers).' },
          { q: 'Does my name get stored anywhere?',
            a: 'No. Everything processes in your browser. We never send your name to a server or store any data.' },
          { q: 'What are the pen type options?',
            a: 'Choose from Ballpoint (clean consistent stroke), Ink / Fountain Pen (soft feathering effect), or Gel Pen (smooth vivid output) — each in multiple colors.' },
        ].map(faq => (
          <details class="group rounded-2xl p-5 transition-all style-card" style="background:var(--color-surface);border:1px solid var(--color-border);">
            <summary class="flex cursor-pointer items-center justify-between font-semibold list-none gap-4" style="color:var(--color-text);">
              {faq.q}
              <svg class="shrink-0 transition-transform duration-200 group-open:rotate-180" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </summary>
            <p class="mt-3 text-sm leading-relaxed" style="color:var(--color-text-muted);">{faq.a}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- ── BOTTOM AD ── -->
    <div class="mx-auto max-w-5xl px-4 sm:px-6 mb-12">
      <div class="ad-slot h-[90px]">· advertisement ·</div>
    </div>

  </main>

  <Footer />
</Layout>
