---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SignatureGenerator from '../components/SignatureGenerator';
import { POPULAR_NAMES } from '../lib/names';

const POPULAR = POPULAR_NAMES.slice(0, 30);

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "SignatureMakr — Free Online Signature Generator",
  "url": "https://www.signaturemakr.com",
  "description": "Create a beautiful free signature online. 10 elegant handwriting styles. Download as PNG or SVG instantly.",
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
};
---

<Layout
  title="Free Signature Generator — Create Beautiful Signatures Online | SignatureMakr"
  description="Create a stunning free signature in seconds. 10 elegant cursive & calligraphy styles. Type your name, customize color & size, download as PNG or SVG. No sign-up needed."
  canonical="https://www.signaturemakr.com/"
  schema={schema}
>
  <Header />

  <main id="main-content">

    <!-- Hero -->
    <section class="relative overflow-hidden py-16 sm:py-24">
      <div class="pointer-events-none absolute inset-0 -z-10">
        <div class="absolute -top-40 -right-40 w-96 h-96 rounded-full bg-violet-500/8 blur-3xl"></div>
        <div class="absolute -bottom-20 -left-20 w-72 h-72 rounded-full bg-pink-500/8 blur-3xl"></div>
      </div>

      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <div class="text-center mb-10" data-scroll="fade">
          <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-violet-200/60 bg-violet-50/60 px-4 py-1.5 text-sm font-semibold text-violet-700 dark:border-violet-800/60 dark:bg-violet-900/30 dark:text-violet-300">
            ✦ 100% Free · No Sign-Up · Instant Download
          </div>
          <h1 class="text-4xl font-black tracking-tight sm:text-6xl bg-gradient-to-br from-violet-700 via-purple-600 to-pink-500 bg-clip-text text-transparent mb-4">
            Free Signature Generator
          </h1>
          <p class="mx-auto max-w-xl text-lg text-[var(--color-text-muted)]">
            Type your name. Pick a style. Download your signature as PNG or SVG — in under 10 seconds.
          </p>
        </div>

        <!-- Generator tool -->
        <div data-scroll="fade">
          <SignatureGenerator client:load />
        </div>
      </div>
    </section>

    <!-- Ad slot -->
    <div class="mx-auto max-w-6xl px-4 sm:px-6 mb-10">
      <div class="ad-slot h-24 w-full rounded-2xl" aria-hidden="true">Advertisement</div>
    </div>

    <!-- Features -->
    <section class="mx-auto max-w-6xl px-4 sm:px-6 py-12" data-scroll>
      <h2 class="text-2xl font-black text-center mb-10">Why SignatureMakr?</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {[
          { icon: '⚡', title: 'Instant Results', desc: 'See your signature update live as you type. No waiting, no loading.' },
          { icon: '🎨', title: '10 Elegant Styles', desc: 'From formal calligraphy to casual brush lettering — find your perfect look.' },
          { icon: '📥', title: 'PNG & SVG Download', desc: 'High-resolution PNG for docs and emails. Scalable SVG for designers.' },
          { icon: '🔒', title: 'No Sign-Up', desc: 'We never ask for your email or account. Open, use, download, done.' },
          { icon: '📱', title: 'Works Everywhere', desc: 'Mobile, tablet, desktop — pixel-perfect on every screen.' },
          { icon: '🌍', title: 'Any Name, Any Language', desc: 'Works with all Latin characters including accented names.' },
        ].map(f => (
          <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
            <div class="mb-3 text-3xl">{f.icon}</div>
            <h3 class="font-bold mb-1">{f.title}</h3>
            <p class="text-sm text-[var(--color-text-muted)]">{f.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Popular names grid -->
    <section class="mx-auto max-w-6xl px-4 sm:px-6 py-12" data-scroll>
      <h2 class="text-2xl font-black text-center mb-2">Signature by Name</h2>
      <p class="text-center text-[var(--color-text-muted)] mb-8">Browse signature styles for popular names</p>
      <div class="flex flex-wrap gap-2 justify-center">
        {POPULAR.map(name => (
          <a
            href={`/signature/${name.toLowerCase()}/`}
            class="rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-2 text-sm font-semibold text-[var(--color-text-muted)] hover:border-violet-400 hover:text-violet-600 hover:bg-violet-50 dark:hover:bg-violet-900/20 transition-all"
          >
            {name}
          </a>
        ))}
        <a href="/signature/" class="rounded-full bg-gradient-to-r from-violet-600 to-purple-600 px-4 py-2 text-sm font-bold text-white hover:opacity-90 transition-all">
          View All Names →
        </a>
      </div>
    </section>

    <!-- FAQ / SEO content -->
    <section class="mx-auto max-w-3xl px-4 sm:px-6 py-12" data-scroll>
      <h2 class="text-2xl font-black text-center mb-8">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {[
          {
            q: 'Is SignatureMakr really free?',
            a: 'Yes — completely free, forever. No subscription, no watermark, no hidden fees. Type your name, choose a style, and download.',
          },
          {
            q: 'Can I use my signature on legal documents?',
            a: 'SignatureMakr creates decorative/stylistic signatures for personal use, social media, emails, and creative projects. For legally binding e-signatures on contracts, use a dedicated e-sign service.',
          },
          {
            q: 'What formats can I download?',
            a: 'PNG (high-resolution, 3× retina-ready) and SVG (vector, infinitely scalable). PNG works great for emails and documents; SVG is perfect for designers.',
          },
          {
            q: 'Does my name get stored or shared?',
            a: 'No. Everything happens in your browser. We never send your name to a server, store it, or share it with anyone.',
          },
          {
            q: 'Can I change the color of my signature?',
            a: 'Yes — choose from 10 curated colors including midnight navy, royal blue, violet, rose, forest green, and more.',
          },
        ].map(faq => (
          <details class="group rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5">
            <summary class="flex cursor-pointer items-center justify-between font-semibold list-none">
              {faq.q}
              <svg class="shrink-0 transition-transform group-open:rotate-180" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <p class="mt-3 text-sm text-[var(--color-text-muted)] leading-relaxed">{faq.a}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- Second ad slot -->
    <div class="mx-auto max-w-6xl px-4 sm:px-6 mb-10">
      <div class="ad-slot h-24 w-full rounded-2xl" aria-hidden="true">Advertisement</div>
    </div>

  </main>

  <Footer />
</Layout>
