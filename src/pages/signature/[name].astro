---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SignatureGenerator from '../../components/SignatureGenerator';
import { POPULAR_NAMES } from '../../lib/names';
import { NAME_CONTENT, getNameMeta, signatureNote } from '../../lib/nameContent';
import { SIGNATURE_FONTS } from '../../lib/fonts';

export function getStaticPaths() {
  return POPULAR_NAMES.map(name => ({
    params: { name: name.toLowerCase() },
    props: { name },
  }));
}

const { name } = Astro.props;
const slug = name.toLowerCase();
const meta = getNameMeta(name);
const cap  = name.charAt(0).toUpperCase() + name.slice(1).toLowerCase();
const content = NAME_CONTENT[slug];
const note = signatureNote(cap);

// Resolve recommended styles to full font objects.
const recommended = (content?.styles ?? [])
  .map(id => SIGNATURE_FONTS.find(f => f.id === id))
  .filter((f): f is typeof SIGNATURE_FONTS[number] => Boolean(f));

// Related names (same first letter, from the curated list).
const related = POPULAR_NAMES
  .filter(n => n.toLowerCase() !== slug && n.charAt(0).toLowerCase() === cap.charAt(0).toLowerCase())
  .slice(0, 8);

const faqs = [
  { q: `What does the name ${cap} mean?`,
    a: content ? `${cap} is of ${content.origin} origin and means "${content.meaning}".` : `${cap} is a popular given name used around the world.` },
  { q: `Is the ${cap} signature generator free?`,
    a: `Yes. Creating and downloading a ${cap} signature is completely free — no account, no watermark, and no sign-up.` },
  { q: `Can I download my ${cap} signature?`,
    a: `Yes. Download your ${cap} signature as a high-resolution PNG (great for emails and documents) or a scalable SVG (ideal for design tools).` },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "name": meta.title,
      "description": meta.description,
      "url": `https://www.digitalsignaturepro.com/signature/${slug}/`
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.digitalsignaturepro.com/" },
        { "@type": "ListItem", "position": 2, "name": "By Name", "item": "https://www.digitalsignaturepro.com/signature/" },
        { "@type": "ListItem", "position": 3, "name": `${cap} Signature` }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<Layout
  title={meta.title}
  description={meta.description}
  canonical={`https://www.digitalsignaturepro.com/signature/${slug}/`}
  schema={schema}
>
  <Header />

  <main id="main-content" class="mx-auto max-w-6xl px-4 sm:px-6 py-12">

    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm text-[var(--color-text-muted)]" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2">
        <li><a href="/" class="hover:opacity-80 transition-colors">Home</a></li>
        <li aria-hidden="true">›</li>
        <li><a href="/signature/" class="hover:opacity-80 transition-colors">By Name</a></li>
        <li aria-hidden="true">›</li>
  