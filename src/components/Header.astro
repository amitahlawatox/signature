---
const pathname = Astro.url.pathname;
---
<header class="sticky top-0 z-40 w-full border-b border-[var(--color-border)] bg-[var(--color-bg)]/80 backdrop-blur-xl">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6">

    <!-- Logo -->
    <a href="/" class="group flex items-center gap-2.5" aria-label="SignatureMakr home">
      <svg width="34" height="34" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"
        class="flex-shrink-0 transition-all duration-300 group-hover:scale-110 group-hover:drop-shadow-[0_0_10px_rgba(124,58,237,0.6)]">
        <defs>
          <radialGradient id="sbg" cx="30%" cy="25%" r="80%">
            <stop offset="0%"   stop-color="#a78bfa"/>
            <stop offset="50%"  stop-color="#7c3aed"/>
            <stop offset="100%" stop-color="#4c1d95"/>
          </radialGradient>
          <linearGradient id="stint" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%"   stop-color="#6366f1" stop-opacity="0"/>
            <stop offset="100%" stop-color="#ec4899" stop-opacity="0.6"/>
          </linearGradient>
          <linearGradient id="sshine" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%"   stop-color="#fff" stop-opacity="0.28"/>
            <stop offset="100%" stop-color="#fff" stop-opacity="0"/>
          </linearGradient>
          <clipPath id="src"><rect width="32" height="32" rx="7.5"/></clipPath>
        </defs>
        <g clip-path="url(#src)">
          <rect width="32" height="32" fill="url(#sbg)"/>
          <rect width="32" height="32" fill="url(#stint)"/>
          <rect width="32" height="32" fill="url(#sshine)"/>
          <!-- Stylised S-curve lettermark -->
          <path d="M20 9 C20 9 12 9 12 13 C12 17 20 15 20 19 C20 23 12 23 12 23"
            fill="none" stroke="white" stroke-width="2.8" stroke-linecap="round"/>
        </g>
      </svg>
      <span class="text-xl font-black tracking-tight bg-gradient-to-r from-violet-600 via-purple-500 to-pink-500 bg-clip-text text-transparent">
        SignatureMakr
      </span>
    </a>

    <!-- Nav -->
    <nav class="hidden items-center gap-1 md:flex" aria-label="Main navigation">
      <a href="/" class={`rounded-lg px-3 py-2 text-sm font-semibold transition-colors hover:text-violet-600 ${pathname === '/' ? 'text-violet-600' : 'text-[var(--color-text-muted)]'}`}>Home</a>
      <a href="/styles/" class={`rounded-lg px-3 py-2 text-sm font-semibold transition-colors hover:text-violet-600 ${pathname.startsWith('/styles') ? 'text-violet-600' : 'text-[var(--color-text-muted)]'}`}>Styles</a>
      <a href="/signature/" class={`rounded-lg px-3 py-2 text-sm font-semibold transition-colors hover:text-violet-600 ${pathname.startsWith('/signature') ? 'text-violet-600' : 'text-[var(--color-text-muted)]'}`}>By Name</a>
    </nav>

    <!-- Right actions -->
    <div class="flex items-center gap-2">
      <button
        onclick="window.__toggleTheme()"
        class="rounded-xl p-2.5 text-[var(--color-text-muted)] hover:bg-[var(--color-surface)] hover:text-[var(--color-text)] transition-all"
        aria-label="Toggle dark mode"
      >
        <svg class="dark:hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg class="hidden dark:block" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      </button>
      <a href="/" class="hidden sm:flex items-center gap-1.5 rounded-xl bg-gradient-to-r from-violet-600 to-purple-600 px-4 py-2 text-sm font-bold text-white hover:opacity-90 transition-all">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        Create Free
      </a>
    </div>
  </div>
</header>
