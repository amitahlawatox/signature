---
const year = new Date().getFullYear();
const nameLinks = ['James','Emma','Sophia','Liam','Olivia','Noah','Ava','William','Isabella','Lucas'];
const styleLinks = [
  { label: 'Elegant Script',  href: '/style/great-vibes/' },
  { label: 'Calligraphy',     href: '/style/pinyon-script/' },
  { label: 'Refined',         href: '/style/alex-brush/' },
  { label: 'Natural',         href: '/style/dancing-script/' },
  { label: 'Expressive',      href: '/style/mr-dafoe/' },
];
---
<footer style="border-top:1px solid var(--color-border);background:var(--color-surface);margin-top:4rem;">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">

    <div class="mb-10 flex flex-col sm:flex-row sm:items-start sm:justify-between gap-6">
      <div class="max-w-xs">
        <a href="/" class="inline-flex items-center gap-2.5">
          <div class="flex h-8 w-8 items-center justify-center rounded-xl" style="background:var(--color-accent);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M17 3 C17 3 9 3 9 8 C9 13 17 11 17 16 C17 21 9 21 9 21"
                stroke="white" stroke-width="2.2" stroke-linecap="round"/>
            </svg>
          </div>
          <span class="text-lg font-black" style="color:var(--color-accent);">SignatureMakr</span>
        </a>
        <p class="mt-2 text-sm leading-relaxed" style="color:var(--color-text-muted);">
          Free online signature generator. 10 professional styles. Download PNG or SVG instantly. No sign-up needed.
        </p>
        <div class="mt-3 flex gap-2 flex-wrap">
          <span class="inline-flex items-center gap-1 rounded-full px-3 py-1 text-xs font-medium"
            style="background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.2);color:#166534;">✓ 100% Free</span>
          <span class="inline-flex items-center gap-1 rounded-full px-3 py-1 text-xs font-medium"
            style="background:var(--color-accent-subtle);border:1px solid var(--color-accent-border);color:var(--color-accent);">⚡ Instant</span>
          <span class="inline-flex items-center gap-1 rounded-full px-3 py-1 text-xs font-medium"
            style="background:var(--color-surface-2);border:1px solid var(--color-border);color:var(--color-text-muted);">🔒 No sign-up</span>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-8 sm:grid-cols-3">
      <div>
        <h3 class="mb-4 text-xs font-bold uppercase tracking-widest" style="color:var(--color-text);">Styles</h3>
        <ul class="space-y-2">
          {styleLinks.map(l => (
            <li>
              <a href={l.href} class="text-sm transition-colors" style="color:var(--color-text-muted);"
                onmouseover="this.style.color='var(--color-accent)'"
                onmouseout="this.style.color='var(--color-text-muted)'">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="mb-4 text-xs font-bold uppercase tracking-widest" style="color:var(--color-text);">Popular Names</h3>
        <ul class="space-y-2">
          {nameLinks.map(n => (
            <li>
              <a href={`/signature/${n.toLowerCase()}/`} class="text-sm transition-colors" style="color:var(--color-text-muted);"
                onmouseover="this.style.color='var(--color-accent)'"
                onmouseout="this.style.color='var(--color-text-muted)'">
                {n} Signature
              </a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="mb-4 text-xs font-bold uppercase tracking-widest" style="color:var(--color-text);">Company</h3>
        <ul class="space-y-2">
          {['About', 'Privacy Policy', 'Terms of Service'].map(l => (
            <li>
              <a href={`/${l.toLowerCase().replace(/\s+/g,'-')}/`} class="text-sm transition-colors" style="color:var(--color-text-muted);"
                onmouseover="this.style.color='var(--color-accent)'"
                onmouseout="this.style.color='var(--color-text-muted)'">
                {l}
              </a>
            </li>
          ))}
        </ul>
        <div class="mt-5">
          <h3 class="mb-2 text-xs font-bold uppercase tracking-widest" style="color:var(--color-text);">Contact</h3>
          <a href="mailto:contact@signaturemakr.com" class="text-sm transition-colors" style="color:var(--color-text-muted);"
            onmouseover="this.style.color='var(--color-accent)'"
            onmouseout="this.style.color='var(--color-text-muted)'">
            contact@signaturemakr.com
          </a>
        </div>
      </div>
    </div>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-between gap-3 pt-6 text-xs"
      style="border-top:1px solid var(--color-border);color:var(--color-text-muted);">
      <p>&copy; {year} SignatureMakr. All rights reserved.</p>
      <p>Made for professionals, students, and creatives.</p>
    </div>
  </div>
</footer>
