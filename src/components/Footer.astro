---
const year = new Date().getFullYear();
const nameLinks = ['James','Emma','Sophia','Liam','Olivia','Noah','Ava','William','Isabella','Lucas'];
const styleLinks = [
  { label: 'Elegant Script', href: '/style/elegant/' },
  { label: 'Classic Cursive', href: '/style/classic/' },
  { label: 'Bold Signature', href: '/style/bold/' },
  { label: 'Delicate Style', href: '/style/delicate/' },
  { label: 'Flowing Script', href: '/style/flowing/' },
];
---
<footer class="border-t border-[var(--color-border)] bg-[var(--color-surface)] mt-16">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">

    <div class="mb-10 flex flex-col sm:flex-row sm:items-start sm:justify-between gap-6">
      <div class="max-w-xs">
        <a href="/" class="inline-flex items-center gap-2.5 group">
          <svg width="30" height="30" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" class="flex-shrink-0">
            <defs>
              <radialGradient id="fbg2" cx="30%" cy="25%" r="80%">
                <stop offset="0%"   stop-color="#a78bfa"/>
                <stop offset="50%"  stop-color="#7c3aed"/>
                <stop offset="100%" stop-color="#4c1d95"/>
              </radialGradient>
              <linearGradient id="ftint2" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%"   stop-color="#6366f1" stop-opacity="0"/>
                <stop offset="100%" stop-color="#ec4899" stop-opacity="0.6"/>
              </linearGradient>
              <clipPath id="frc2"><rect width="32" height="32" rx="7.5"/></clipPath>
            </defs>
            <g clip-path="url(#frc2)">
              <rect width="32" height="32" fill="url(#fbg2)"/>
              <rect width="32" height="32" fill="url(#ftint2)"/>
              <path d="M20 9 C20 9 12 9 12 13 C12 17 20 15 20 19 C20 23 12 23 12 23"
                fill="none" stroke="white" stroke-width="2.8" stroke-linecap="round"/>
            </g>
          </svg>
          <span class="text-lg font-black bg-gradient-to-r from-violet-600 to-pink-500 bg-clip-text text-transparent">SignatureMakr</span>
        </a>
        <p class="mt-2 text-sm text-[var(--color-text-muted)] leading-relaxed">
          Free online signature generator. 10 elegant styles. Download as PNG or SVG instantly. No sign-up needed.
        </p>
        <div class="mt-3 flex gap-2 flex-wrap">
          <span class="inline-flex items-center gap-1 rounded-full border border-green-200/50 bg-green-50/50 px-3 py-1 text-xs font-medium text-green-700 dark:border-green-800/50 dark:bg-green-900/20 dark:text-green-400">✓ 100% Free</span>
          <span class="inline-flex items-center gap-1 rounded-full border border-violet-200/50 bg-violet-50/50 px-3 py-1 text-xs font-medium text-violet-700 dark:border-violet-800/50 dark:bg-violet-900/20 dark:text-violet-400">⚡ Instant</span>
          <span class="inline-flex items-center gap-1 rounded-full border border-indigo-200/50 bg-indigo-50/50 px-3 py-1 text-xs font-medium text-indigo-700 dark:border-indigo-800/50 dark:bg-indigo-900/20 dark:text-indigo-400">🔒 No sign-up</span>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-8 sm:grid-cols-3">
      <div>
        <h3 class="mb-4 text-xs font-bold uppercase tracking-widest text-[var(--color-text)]">Styles</h3>
        <ul class="space-y-2">
          {styleLinks.map(l => (
            <li><a href={l.href} class="text-sm text-[var(--color-text-muted)] hover:text-violet-600 transition-colors">{l.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="mb-4 text-xs font-bold uppercase tracking-widest text-[var(--color-text)]">Popular Names</h3>
        <ul class="space-y-2">
          {nameLinks.map(n => (
            <li><a href={`/signature/${n.toLowerCase()}/`} class="text-sm text-[var(--color-text-muted)] hover:text-violet-600 transition-colors">{n} Signature</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="mb-4 text-xs font-bold uppercase tracking-widest text-[var(--color-text)]">Company</h3>
        <ul class="space-y-2">
          <li><a href="/about/" class="text-sm text-[var(--color-text-muted)] hover:text-violet-600 transition-colors">About</a></li>
          <li><a href="/privacy/" class="text-sm text-[var(--color-text-muted)] hover:text-violet-600 transition-colors">Privacy Policy</a></li>
          <li><a href="/terms/" class="text-sm text-[var(--color-text-muted)] hover:text-violet-600 transition-colors">Terms of Service</a></li>
        </ul>
        <div class="mt-5">
          <h3 class="mb-2 text-xs font-bold uppercase tracking-widest text-[var(--color-text)]">Contact</h3>
          <a href="mailto:contact@signaturemakr.com" class="text-sm text-[var(--color-text-muted)] hover:text-violet-600 transition-colors">contact@signaturemakr.com</a>
        </div>
      </div>
    </div>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-between gap-3 border-t border-[var(--color-border)] pt-6 text-xs text-[var(--color-text-muted)]">
      <p>&copy; {year} SignatureMakr. All rights reserved.</p>
      <p>Made with ✨ for professionals, students, and creatives.</p>
    </div>
  </div>
</footer>
