---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  schema?: object;
  noIndex?: boolean;
}
const { title, description, canonical, ogImage = '/og-image.png', schema, noIndex } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#1d3f6e" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <title>{title}</title>
    <meta name="description" content={description.slice(0, 160)} />
    <link rel="canonical" href={canonical} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description.slice(0, 160)} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="SignatureMakr" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description.slice(0, 160)} />
    <meta name="twitter:image" content={ogImage} />

    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    {schema && <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />}

    <!-- Light mode by default; .dark class enables dark mode -->
    <script is:inline>
      (function(){
        try {
          if (localStorage.getItem('sm-theme') === 'dark')
            document.documentElement.classList.add('dark');
        } catch(e) {}
        window.__toggleTheme = function(){
          var isDark = document.documentElement.classList.toggle('dark');
          try { localStorage.setItem('sm-theme', isDark ? 'dark' : 'light'); } catch(e) {}
        };
      })();
    </script>
    <slot name="head" />
  </head>

  <body class="min-h-screen antialiased" style="background:var(--color-bg);color:var(--color-text);">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:rounded-lg focus:px-4 focus:py-2 focus:text-white focus:outline-none"
      style="background:var(--color-accent);">
      Skip to content
    </a>

    <slot />

    <script is:inline>
      (function(){
        document.addEventListener('click', function(e){
          var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          if (reduced) return;
          var t = e.target.closest('a[href],button');
          if (!t) return;
          var r = t.getBoundingClientRect();
          var rp = document.createElement('span');
          rp.className = 'ripple-effect';
          rp.style.left = (e.clientX - r.left) + 'px';
          rp.style.top  = (e.clientY - r.top) + 'px';
          if (getComputedStyle(t).position === 'static') t.style.position = 'relative';
          t.style.overflow = 'hidden';
          t.appendChild(rp);
          setTimeout(function(){ rp.parentNode && rp.parentNode.removeChild(rp); }, 700);
        });
      })();
    </script>

    <script is:inline>
      (function(){
        if (typeof IntersectionObserver === 'undefined') return;
        var obs = new IntersectionObserver(function(entries){
          entries.forEach(function(e){
            if (e.isIntersecting){ e.target.classList.add('scroll-visible'); obs.unobserve(e.target); }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
        function observe(){ document.querySelectorAll('[data-scroll]').forEach(function(el){ obs.observe(el); }); }
        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', observe);
        else observe();
      })();
    </script>

    {import.meta.env.PROD && <script is:inline defer src="/_vercel/insights/script.js"></script>}
  </body>
</html>
